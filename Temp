# ── Router ────────────────────────────────────────────────────────────────────
def main():
    args = sys.argv[1:]

    if not args:
        cmd_summary()
        return

    labels = get_labels()

    # Try: "LABEL name: text" -> append to per-label file
    joined = " ".join(args)
    m = re.match(r"(?i)^(?P<label>\w+)\s+(?P<name>[^:]+):\s*(?P<text>.+)$", joined)
    if m:
        lbl = resolve_label(m.group("label"))
        if lbl:
            name = m.group("name").strip()
            text = m.group("text").strip()
            cmd_append_file(lbl, name, text)
            return

    # Try: "LABEL open name" -> open per-label file
    m2 = re.match(r"(?i)^(?P<label>\w+)\s+open\s+(?P<name>.+)$", joined)
    if m2:
        lbl = resolve_label(m2.group("label"))
        if lbl:
            name = m2.group("name").strip()
            cmd_open_file(lbl, name)
            return

    # ── ADD: detect "LABEL: text ..." (existing behavior)
    for label in labels:
        prefix = label.upper() + ":"
        if joined.upper().startswith(prefix):
            text = joined[len(prefix) :].strip()
            if not text:
                print(c(f"\n  Usage: ws {prefix} your text here\n", "dim"))
                return
            cmd_add(label, text)
            return

    first = args[0].lower()
    rest = args[1:]

    # HELP
    if first in ("help", "--help", "-h"):
        cmd_help()
        return

    # SUMMARY
    if first in ("summary", "status", "s"):
        cmd_summary()
        return

    # STATS
    if first in ("stats", "stat"):
        cmd_stats()
        return

    # LIST
    if first in ("list", "ls", "l"):
        if not rest:
            cmd_summary()
            return
        label = resolve_label(rest[0])
        if not label:
            print(c(f"\n  Unknown label '{rest[0]}'.\n", "red"))
            return
        show_all = "--all" in rest
        tag_filter = next((a[1:] for a in rest if a.startswith("#")), None)
        cmd_list(label, show_resolved=show_all, tag_filter=tag_filter)
        return

    # SEARCH
    if first in ("search", "find", "grep", "f"):
        if not rest:
            print(c("\n  Usage: ws search <keyword> [label]\n", "dim"))
            return
        keyword = rest[0]
        label_filter = resolve_label(rest[1]) if len(rest) > 1 else None
        cmd_search(keyword, label_filter)
        return

    # RESOLVE
    if first in ("resolve", "done", "close", "r"):
        if not rest:
            print(c("\n  Usage: ws resolve <label>\n", "dim"))
            return
        label = resolve_label(rest[0])
        if not label:
            print(c(f"\n  Unknown label '{rest[0]}'.\n", "red"))
            return
        cmd_resolve(label)
        return

    # EDIT
    if first in ("edit", "e", "update"):
        if not rest:
            print(c("\n  Usage: ws edit <label>\n", "dim"))
            return
        label = resolve_label(rest[0])
        if not label:
            print(c(f"\n  Unknown label '{rest[0]}'.\n", "red"))
            return
        cmd_edit(label)
        return

    # DELETE
    if first in ("delete", "del", "rm"):
        if not rest:
            print(c("\n  Usage: ws delete <label>\n", "dim"))
            return
        label = resolve_label(rest[0])
        if not label:
            print(c(f"\n  Unknown label '{rest[0]}'.\n", "red"))
            return
        cmd_delete(label)
        return

    # EXPORT
    if first in ("export", "exp", "x"):
        fmt = "md"
        label_filter = None
        for arg in rest:
            if arg in ("md", "json", "txt"):
                fmt = arg
            else:
                lf = resolve_label(arg)
                if lf:
                    label_filter = lf
        cmd_export(fmt, label_filter)
        return

    # LABEL management
    if first in ("label", "labels"):
        cmd_label(rest)
        return

    # Shortcut: "ws doubts" -> list
    label = resolve_label(first)
    if label:
        show_all = "--all" in rest
        tag_filter = next((a[1:] for a in rest if a.startswith("#")), None)
        cmd_list(label, show_resolved=show_all, tag_filter=tag_filter)
        return

    print(c(f"\n  Unknown command '{args[0]}'. Run 'ws help' for usage.\n", "red"))


if __name__ == "__main__":
    main()
